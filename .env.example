# Copy this file to .env and fill in up to three Gemini API keys.
# The pipeline tries key 1 first, then rotates to key 2 and key 3 if a request fails.

GEMINI_API_KEY_1=YOUR_FIRST_GEMINI_API_KEY_HERE
GEMINI_API_KEY_2=YOUR_SECOND_GEMINI_API_KEY_HERE
GEMINI_API_KEY_3=YOUR_THIRD_GEMINI_API_KEY_HERE

# Optional equivalent form:
# GEMINI_API_KEYS=key_one,key_two,key_three
